{
  "name": "job-dash",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply job-dash-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply job-dash-db --remote",
    "deploy": "wrangler deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "@hono/zod-validator": "^0.5.0",
    "nanoid": "^5.1.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vite-plugin": "^1.32.3",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wrangler": "^4.83.0"
  }
